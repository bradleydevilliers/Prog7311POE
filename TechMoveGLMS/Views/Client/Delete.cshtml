@model TechMoveGLMS.Models.Entities.Client

@{
    ViewData["Title"] = "Delete Client";
}
<!--(W3Schools 2026)(Bootstrap Team 2026)-->
<h1>Delete Client</h1>

<h3>Are you sure you want to delete this client?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        
        <dt class="col-sm-2">Contact Details</dt>
        <dd class="col-sm-10">@Model.ContactDetails</dd>
        
        <dt class="col-sm-2">Region</dt>
        <dd class="col-sm-10">@Model.Region</dd>
    </dl>
    <!--(W3Schools 2026)(Bootstrap Team 2026)-->
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
