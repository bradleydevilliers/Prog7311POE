@model TechMoveGLMS.Models.ViewModels.ServiceRequestViewModel

@{
    ViewData["Title"] = "Create Service Request";
}
<!--(W3Schools 2026)(Bootstrap Team 2026)-->
<h1>Create Service Request</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    
    <div class="form-group mb-3">
        <label asp-for="ContractId" class="control-label"></label>
        <select asp-for="ContractId" class="form-control" asp-items="Model.Contracts">
            <option value="">-- Select Active Contract --</option>
        </select>
        <span asp-validation-for="ContractId" class="text-danger"></span>
        <small class="form-text text-muted">Only active, non-expired contracts are shown.</small>
    </div>
    
    <div class="form-group mb-3">
        <label asp-for="ServiceLevel" class="control-label"></label>
        <select asp-for="ServiceLevel" class="form-control" asp-items="Model.ServiceLevels"></select>
        <span asp-validation-for="ServiceLevel" class="text-danger"></span>
    </div>
    
    <div class="form-group mb-3">
        <label asp-for="Description" class="control-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    
    <div class="form-group mb-3">
        <label asp-for="Distance" class="control-label">Distance (kilometers)</label>
        <input asp-for="Distance" class="form-control" type="number" step="0.1" value="0" />
        <span asp-validation-for="Distance" class="text-danger"></span>
    </div>
    
    <div class="form-group mb-3 form-check">
        <input asp-for="IsPriority" class="form-check-input" type="checkbox" />
        <label asp-for="IsPriority" class="form-check-label">Priority Service (additional fee may apply)</label>
    </div>
    
    <div class="form-group mb-3">
        <label class="control-label">Currency Conversion</label>
        <div class="alert alert-info">
            <small>Cost will be calculated in USD and automatically converted to ZAR using live exchange rates.</small>
        </div>
    </div>
    
    <div class="form-group">
        <button type="submit" class="btn btn-primary">Create Service Request</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form><!--(W3Schools 2026)(Bootstrap Team 2026)-->

