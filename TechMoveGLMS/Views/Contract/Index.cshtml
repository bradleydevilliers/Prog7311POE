@model IEnumerable<TechMoveGLMS.Models.Entities.Contract>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Contracts";
     var userRole = HttpContextAccessor.HttpContext?.Session.GetString("UserRole");
    var isAdmin = userRole == "Admin";
}
<!--(W3Schools 2026)(Bootstrap Team 2026)-->
<h1>Contracts</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Contract</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Client</th>
            <th>Service Level</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Agreement</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var isExpired = item.EndDate < DateTime.Now;
            var statusClass = item.Status == "Active" && !isExpired ? "text-success" : 
                              (isExpired ? "text-danger" : "text-warning");
            
            <tr>
                <td>@item.Id</td>
                <td>@item.Client?.Name</td>
                <td>@item.ServiceLevel</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td class="@statusClass">
                    @(isExpired ? "Expired" : item.Status)
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(item.SignedAgreementPath))
                    {
                        <a asp-action="DownloadAgreement" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                            Download PDF
                        </a>
                    }
                </td>
                 @if (isAdmin)
                {
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>
